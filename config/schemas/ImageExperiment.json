{
    "type": "object",
    "title": "ImageExperiment",
    "$schema": "http://json-schema.org/draft-07/schema#",
    "required": [
        "title",
        "preparation_method"
    ],
    "properties": {
        "title": {
            "type": "string",
            "title": "title",
            "description": "The experiment alias"
        },
        "channels": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "channel_content": {
                        "type": "string",
                        "title": "Channel-content",
                        "description": "Specific specimen staining"
                    },
                    "channel_biological_entity": {
                        "type": "string",
                        "title": "Channel - biological entity",
                        "description": "What molecule is stained"
                    }
                }
            }
        },
        "public_id": {
            "type": "string",
            "title": "Public ID",
            "pattern": "^CHFEGAX[0-9]{11}.*",
            "description": "Public Identifier of the experiment"
        },
        "extra_attributes": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "tag",
                    "value"
                ],
                "properties": {
                    "tag": {
                        "type": "string"
                    },
                    "unit": {
                        "type": "string"
                    },
                    "value": {
                        "type": "string"
                    }
                }
            },
            "title": "Extra Attributes",
            "description": "Any extra attribute(s) to describe an experiment"
        },
        "preparation_method": {
            "type": "string",
            "title": "Preparation method",
            "description": "Sample preparation protocol"
        },
        "instrument_attributes": {
            "type": "string",
            "title": "Instrument attributes",
            "description": "Details about instruments used"
        },
        "signal_contrast_mechanism": {
            "type": "string",
            "title": "Signal/contrast mechanism",
            "description": "How is the signal generated by this sample"
        },
        "image_acquisition_parameters": {
            "type": "string",
            "title": "Image acquisition parameters",
            "description": "Image acquisition details"
        }
    },
    "x-resource": {
        "schema": {
            "fields": [
                {
                    "name": "title",
                    "constraints": {
                        "required": true
                    }
                },
                {
                    "name": "preparation_method",
                    "constraints": {
                        "required": true
                    }
                }
            ],
            "primaryKey": [
                "title"
            ]
        }
    }
}