{
  "output": "fega.phar",
  "main": "bin/console",
  "directories": ["src", "config", "vendor", "public"],
  "files": ["composer.json"],
  "blacklist": ["public/index.php"],
  "exclude-composer-files": false,
  "exclude-dev-files": true,
  "compression": "GZ",
  "compactors": ["KevinGH\\Box\\Compactor\\Php"],
  "annotations": {
    "ignore": ["author", "since", "version"]
  },
  "stub": "bin/console.stub"
}
